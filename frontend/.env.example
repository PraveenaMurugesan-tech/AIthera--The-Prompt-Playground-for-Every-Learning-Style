# ==========================================
# AIthera Frontend Environment Variables
# ==========================================

# API Configuration
# Points to the FastAPI backend URL
# For production, this should be the domain of your deployed backend
# Example: https://api.aithera.com
VITE_API_URL=http://localhost:8000

# Performance Monitoring (Optional)
# Enable or disable the performance monitor logging in dev mode
VITE_ENABLE_PERF_MONITOR=true
